"""Fixtures and shared step definitions for BDD integration tests."""

import pytest
from pytest_bdd import given, when, then, parsers

from {{ module_name }}.main import create_app


# ---------------------------------------------------------------------------
# BDD shared state
# ---------------------------------------------------------------------------


@pytest.fixture
def bdd_context() -> dict:
    """Mutable dict shared across all steps in a single scenario."""
    return {}


# ---------------------------------------------------------------------------
# Shared Given steps
# ---------------------------------------------------------------------------


@given("the Flask test client is ready")
def flask_client_ready(bdd_context: dict) -> None:
    app = create_app()
    bdd_context["client"] = app.test_client()


# ---------------------------------------------------------------------------
# Shared When steps
# ---------------------------------------------------------------------------


@when(parsers.parse('I GET "{path}"'))
def get_request(path: str, bdd_context: dict) -> None:
    client = bdd_context["client"]
    bdd_context["response"] = client.get(path)


# ---------------------------------------------------------------------------
# Shared Then steps
# ---------------------------------------------------------------------------


@then(parsers.parse("the response status is {code:d}"))
def response_status(code: int, bdd_context: dict) -> None:
    response = bdd_context["response"]
    assert response.status_code == code, (
        f"Expected status {code}, got {response.status_code}"
    )


@then("the response body is valid JSON")
def response_is_json(bdd_context: dict) -> None:
    response = bdd_context["response"]
    assert response.json is not None, "Expected a JSON response body"


@then(parsers.parse('the output contains "{text}"'))
def output_contains(text: str, bdd_context: dict) -> None:
    output = bdd_context.get("output", "")
    assert text in output, f"Expected {text!r} in output.\nActual output:\n{output}"
